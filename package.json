{
    "publishConfig": {
        "tag": "alpha"
    },
    "name": "filepond",
    "version": "5.0.0-alpha.4",
    "description": "FilePond, where files go to stretch their bits.",
    "author": "Rik Schennink",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "dev": "vite --host",
        "dev-clean": "NODE_ENV=production vite --host",
        "test": "vite --port 5175 --open /test/",
        "build": "vite build && npm run ts",
        "ts": "tsc -p ./tsconfig.build.json && cp src/types/*.d.ts dist/types && echo 'import \"./custom-element.js\";\nimport \"./default-extensions.js\";' >> dist/types/index.d.ts",
        "prepublishOnly": "node before-publish.js"
    },
    "files": [
        "./dist"
    ],
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/esm/index.js"
        },
        "./extensions": {
            "types": "./dist/types/extensions/index.d.ts",
            "import": "./dist/esm/extensions/index.js"
        },
        "./extensions/*": {
            "types": "./dist/types/extensions/*.d.ts",
            "import": "./dist/esm/extensions/*.js"
        },
        "./elements": {
            "types": "./dist/types/elements/index.d.ts",
            "import": "./dist/esm/elements/index.js"
        },
        "./locales": {
            "types": "./dist/types/locales/index.d.ts",
            "import": "./dist/esm/locales/index.js"
        },
        "./locales/*": {
            "types": "./dist/types/locales/*.d.ts",
            "import": "./dist/esm/locales/*"
        },
        "./assets": {
            "types": "./dist/types/locales/index.d.ts",
            "import": "./dist/esm/assets/index.js"
        }
    },
    "devDependencies": {
        "@sveltejs/vite-plugin-svelte": "^6.0.0",
        "chai": "^4.3.7",
        "chokidar-cli": "^3.0.0",
        "eslint-plugin-svelte": "^2.46.1",
        "glob": "^11.0.3",
        "http-server": "^14.1.1",
        "mocha": "^10.2.0",
        "mocha-headless-chrome": "^4.0.0",
        "prettier-plugin-jsdoc": "^1.3.0",
        "prettier-plugin-svelte": "^3.4.0",
        "replace-in-files-cli": "^3.0.0",
        "sinon": "^15.0.1",
        "svelte": "^5.43.6",
        "svelte-check": "^4.3.1",
        "typescript": "^5.9.2",
        "unplugin-dts": "^1.0.0-beta.0",
        "vite": "^7.1.3",
        "vite-plugin-dts": "^4.5.4",
        "vite-plugin-static-copy": "^3.1.2"
    }
}
