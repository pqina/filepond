{
    "publishConfig": {
        "tag": "beta"
    },
    "name": "filepond",
    "version": "5.0.0-beta.9",
    "description": "FilePond, where files go to stretch their bits.",
    "author": "Rik Schennink",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "dev": "vite --host",
        "dev-optimal": "NODE_ENV=production vite --host",
        "test": "vite --port 5175 --open /test/",
        "build": "npm run esm && npm run cdn && npm run types",
        "esm": "rm -rf ./esm && vite build",
        "types": "rm -rf ./types && tsc -p ./tsconfig.build.json && cp src/types/*.d.ts types && echo 'import \"./custom-element.js\";\nimport \"./default-extensions.js\";' >> types/index.d.ts",
        "cdn": "rm -rf ./cdn && rollup -c rollup.config.js",
        "prepublishOnly": "npm run build && node prepublish.js"
    },
    "files": [
        "./esm",
        "./cdn",
        "./types"
    ],
    "browser": "./cdn/index.js",
    "module": "./esm/index.js",
    "types": "./types/index.d.ts",
    "exports": {
        ".": {
            "types": "./types/index.d.ts",
            "import": "./esm/index.js"
        },
        "./extensions": {
            "types": "./types/extensions/index.d.ts",
            "import": "./esm/extensions/index.js"
        },
        "./extensions/*": {
            "types": "./types/extensions/*.d.ts",
            "import": "./esm/extensions/*.js"
        },
        "./elements": {
            "types": "./types/elements/index.d.ts",
            "import": "./esm/elements/index.js"
        },
        "./templates": {
            "types": "./types/templates/index.d.ts",
            "import": "./esm/templates/index.js"
        },
        "./locales": {
            "types": "./types/locales/index.d.ts",
            "import": "./esm/locales/index.js"
        },
        "./locales/*": {
            "types": "./types/locales/*.d.ts",
            "import": "./esm/locales/*"
        },
        "./assets": {
            "types": "./types/locales/index.d.ts",
            "import": "./esm/assets/index.js"
        }
    },
    "devDependencies": {
        "@rollup/plugin-terser": "^0.4.4",
        "@sveltejs/vite-plugin-svelte": "^6.0.0",
        "@typescript-eslint/types": "^8.48.1",
        "chai": "^4.3.7",
        "chokidar-cli": "^3.0.0",
        "eslint-plugin-svelte": "^2.46.1",
        "glob": "^11.0.3",
        "http-server": "^14.1.1",
        "mocha": "^10.2.0",
        "mocha-headless-chrome": "^4.0.0",
        "prettier-plugin-jsdoc": "^1.3.0",
        "prettier-plugin-svelte": "^3.4.0",
        "replace-in-files-cli": "^3.0.0",
        "rollup": "^4.53.3",
        "rollup-plugin-cleanup": "^3.2.1",
        "rollup-plugin-license": "^3.6.0",
        "sinon": "^15.0.1",
        "svelte": "^5.45.6",
        "svelte-check": "^4.3.1",
        "typescript": "^5.9.2",
        "unplugin-dts": "^1.0.0-beta.0",
        "vite": "^7.2.6",
        "vite-plugin-dts": "^4.5.4",
        "vite-plugin-static-copy": "^3.1.2"
    }
}
